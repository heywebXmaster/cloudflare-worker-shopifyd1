{
  "name": "shopify-cloudflare-d1-template",
  "description": "Shopify App template using Remix + Cloudflare Workers + D1.",
  "dependencies": {
    "@remix-run/cloudflare": "^2.16.5",
    "@remix-run/dev": "^2.16.5",
    "@remix-run/fs-routes": "^2.16.5",
    "@remix-run/node": "^2.16.5",
    "@remix-run/react": "^2.16.5",
    "@remix-run/serve": "^2.16.5",
    "@shopify/app-bridge-react": "^4.1.10",
    "@shopify/polaris": "^13.9.5",
    "@shopify/shopify-app-remix": "^4.1.0",
    "isbot": "^5.1.26",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250404.0",
    "@remix-run/route-config": "^2.16.5",
    "@types/node": "^22.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "8.31.0",
    "@typescript-eslint/parser": "8.31.0",
    "autoprefixer": "10.4.21",
    "eslint": "9.25.1",
    "eslint-import-resolver-typescript": "3.7.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "8.5.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3",
    "vite": "^6.2.2",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.13.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true,
  "scripts": {
    "clean": "rimraf build/server",
    "build": "run-s clean build:remix",
    "build:remix": "remix vite:build",
    "cf-typegen": "wrangler types",
    "check": "run-s typecheck build deploy:dry",
    "deploy": "run-s build deploy:wrangler",
    "deploy:wrangler": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run",
    "dev": "remix vite:dev",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "preview": "run-s build start",
    "start": "wrangler dev",
    "setup": "run-s migrate:d1:local build",
    "setup:remote": "run-s migrate:d1 build",
    "migrate:d1": "wrangler d1 execute your_d1_database_name --command \"ALTER TABLE shopify_sessions ADD COLUMN refreshToken TEXT; ALTER TABLE shopify_sessions ADD COLUMN refreshTokenExpires INTEGER;\"",
    "migrate:d1:local": "wrangler d1 execute your_d1_database_name --local --command \"ALTER TABLE shopify_sessions ADD COLUMN refreshToken TEXT; ALTER TABLE shopify_sessions ADD COLUMN refreshTokenExpires INTEGER;\"",
    "typecheck": "tsc",
    "typegen": "wrangler types"
  },
  "sideEffects": false,
  "type": "module",
  "overrides": {
    "vite": "^6.2.2",
    "wrangler": "^4.13.2"
  }
}
