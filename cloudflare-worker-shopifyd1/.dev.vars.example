# Copy this file to .dev.vars and fill in your values
# .dev.vars is gitignored and used by wrangler for local development

SHOPIFY_API_KEY="your_api_key_from_shopify_dashboard"
SHOPIFY_API_SECRET="your_api_secret_from_shopify_dashboard"
SHOPIFY_APP_URL="https://your-tunnel-url.trycloudflare.com"
SCOPES="write_products"
